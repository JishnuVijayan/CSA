# Environment Variables Template
# Copy this file to .env and update with your values

# ============================================
# DATABASE CONFIGURATION
# ============================================
# PostgreSQL database password
# Local: Use any password (default: adminpassword)
# Production: Use a STRONG password (16+ characters, mix of letters, numbers, symbols)
DB_PASSWORD=your_secure_password_here

# ============================================
# API CONFIGURATION
# ============================================
# Backend API URL - Where the frontend should call the backend
# 
# For LOCAL development:
# NEXT_PUBLIC_API_URL=http://localhost:3001
#
# For PRODUCTION (Lightsail):
# NEXT_PUBLIC_API_URL=http://YOUR_LIGHTSAIL_PUBLIC_IP:3001
# 
# Example: NEXT_PUBLIC_API_URL=http://54.123.45.67:3001
#
# How to find your Lightsail IP:
# 1. Go to AWS Lightsail console
# 2. Click on your instance
# 3. Look for "Public IP" or "Static IP"
# 4. Or SSH in and run: curl ifconfig.me
NEXT_PUBLIC_API_URL=http://localhost:3001
